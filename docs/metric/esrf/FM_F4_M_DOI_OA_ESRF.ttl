@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dpv: <https://w3id.org/dpv#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ftr: <https://w3id.org/ftr#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix vivo: <http://vivoweb.org/ontology/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/fair-metrics/esrf/FM_F4_M_DOI_OA_ESRF>
    a                          ftr:Metric, dcat:Dataset ;
    
    ftr:identifier            "https://w3id.org/fair-metrics/esrf/FM_F4_M_DOI_OA_ESRF"^^xsd:anyURI ;

    dcterms:title             "FAIR Metric – F4 – Metadata - The content associated to a DOI is Open Access" ;
    vivo:abbreviation         "FM_F4_M_DOI_OA_ESRF" ;
    dcterms:description       """ This metric applies to DOI objects. For publications entities, it ensures that its content, or a allowed copy is open access. For dataset entities it ensures that the data is open access (with or without embargo period). The reference services used are : https://unpaywall.org/ and https://openalex.org. While originally created as part of the OSTrails project to fulfil requirements within the PaNOSC cluster, this metric is subject agnostic and can be re-used by any community with these requirements for FAIR F4. """ ;
    dcat:keyword              "FAIR", "open access", "standard", "f4" ;
    rdfs:definedBy <https://fairmetrics.github.io/Metrics/metric/esrf/FM_F4_M_DOI_OA_ESRF.ttl> ;
    dcat:landingPage          <https://fairsharing.org/6449> ;
    
dcterms:creator               [
    a                     foaf:Person ;
    vcard:fn             "Renaud DUYME" ;
    foaf:mbox             <mailto:renaud.duyme@esrf.fr>
] ;

    dcat:contactPoint           [
        a                     vcard:Individual ;
        vcard:fn              "Mark D. Wilkinson" ;
        vcard:organization-name "Wilkinson Laboratory, UPM, Madrid";
        vcard:hasEmail             <mailto:mark.wilkinson@upm.es> ;
    ] ;
    	ftr:status "Active"@en ;
dcat:version           "esrf1.0" ;

ftr:applicationArea       <http://www.fairsharing.org/ontology/subject/SRAO_0000401> ;

dcterms:license           <https://creativecommons.org/licenses/by/4.0/> ;

ftr:supportedBy <https://w3id.org/FAIR-Champion> ;
dpv:isApplicableFor       schema:CreativeWork .  
