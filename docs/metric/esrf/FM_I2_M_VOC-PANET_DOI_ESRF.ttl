<https://w3id.org/fair-metrics/esrf/FM_I2_M_VOC-PANET_DOI_ESRF>
    a                          ftr:Metric, dcat:Dataset ;
    
    ftr:identifier            "https://w3id.org/fair-metrics/esrf/FM_I2_M_VOC-PANET_DOI_ESRF"^^xsd:anyURI ;

    dcterms:title             "FAIR Metric - DOI metadata contains a link to a community ontology term - PaNET" ;
    vivo:abbreviation         "FM_I2_M_VOC-PANET_DOI_ESRF" ;
    dcterms:description       """ This metric ensures that the research object provided by the supplied URL is associated with a DataCite DOI whose metadata contains a PaNET subject term. This means that the DataCite metadata for the research object’s DOI must define a subject from PaNET using schemeUri or subjectScheme. The supplied URL can be one of: a doi.org domain URL or a DOI target repository domain URL.""" ;
    dcat:keyword              "FAIR", "open access", "standard", "f4" ;
    rdfs:isDefinedBy <https://fairmetrics.github.io/Metrics/metric/esrf/FM_I2_M_VOC-PANET_DOI_ESRF.ttl> ;
    dcat:landingPage          <https://fairsharing.org/6465> ;
    
dcat:contactPoint               [
    a                     foaf:Person ;
    vcard:fn             "Renaud DUYME" ;
    foaf:mbox             <mailto:renaud.duyme@esrf.fr>
] ;

    dcat:contactPoint           [
        a                     vcard:Individual ;
        vcard:fn              "Mark D. Wilkinson" ;
        vcard:organization-name "Wilkinson Laboratory, UPM, Madrid";
        vcard:hasEmail             <mailto:mark.wilkinson@upm.es> ;
    ] ;
    	ftr:status "Active"@en ;
dcat:version           "esrf1.0" ;

ftr:applicationArea       <http://www.fairsharing.org/ontology/subject/SRAO_0000401> ;

dcterms:license           <https://creativecommons.org/licenses/by/4.0/> ;

