        ],
        "http://purl.org/dc/terms/description": [
            {
                "@value": "\n                           The ERDERA Project has strict requirements for minimal metadata to onboard their Virtual Platform. \n                            For Level 2, you must first be Level 1 compliant (see https://w3id.org/fair-metrics/erdera/FM_R1-3_M_VP_L1).\n                            In addition, you must declare yourself as a dcat Data Service, and have a landingPage at a minimimum.\n\n"
            }
        ],
