        ],
        "http://purl.org/dc/terms/description": [
            {
                "@value": "The ERDERA Project has strict requirements for minimal metadata to onboard their Virtual Platform. \n                            These include: Migration away from deprecated EJP purl properties to the w3id equivalents.  Presence of the VPDiscoverable prpoperty. Properties: dcat:theme dcat:contactPoint dct:description\n                            dcat:keyword dct:language dct:license\n                            dct:publisher dct:title dcat:contactPoint dcat:landingPage.  \n                        It does not test the substructure of the dct:publisher, but it must be a foaf:Agent with a foaf:name.\n"
            }
        ],
        "http://purl.org/dc/terms/issued": [
