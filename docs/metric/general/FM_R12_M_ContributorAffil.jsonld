      "https://w3id.org/ftr#identifier": {
        "@type": "xsd:anyURI",
        "@value": "https://w3id.org/fair-metrics/general/FM_R12_M_ContributorAffil"
      },
      "dc:title": "FAIR Metric - R1.2 - Metadata - contributor affiliation",
      "http://vivoweb.org/ontology/core#abbreviation": "FM_R12_M_ContributorAffil",
      "dcat:landingPage": {
        "@id": "https://w3id.org/fair-metrics/general/FM_R12_M_ContributorAffil"
      },
      "dc:description": "\n    <p>This metric evaluates whether there is structured affiliation information associated with at least one author or core contributor in the metadata retrieved upon resolution of the provided identifier, providing one facet of evaluation for this R1.2.</p>\n\n<p>R1.2 requires that metadata be associated with detailed provenance. The purpose of \nthis principle is to ensure that the institutional context of authors or contributors is \ndocumented, enabling attribution and transparency. This metric evaluates whether\n there is structured affiliation information associated with at least one author \n or core contributor in the metadata retrieved upon resolution of the provided \n identifier. Under this interpretation, the evaluation checks whether at least \n one identified person (e.g., creator or contributor) is associated with an\n  organisation through a structured affiliation field or relationship. The \n  affiliation must be explicitly represented in the metadata, rather than implied. \nA resource satisfies this metric if at least one author or contributor includes any \nnonzero value in the resolved \nmetadata of the following types only: citation_author_institution field name, \n    DataCite creators affiliation (DOIs only), \n    Crossref author/investigator/lead-investigator affiliation (DOIs only).</p>\n\n",
      "dcat:keyword": [
        "FAIR",
        "R1.2",
        "identifier",
        "metadata"
      ],
