[
    {
        "@id": "https://w3id.org/fair-metrics/general/FM_R12_M_FundInfo",
        "@type": [
            "https://w3id.org/ftr#Metric",
            "http://www.w3.org/ns/dcat#Dataset"
        ],
        "http://purl.org/dc/terms/creator": [
