        ],
        "http://purl.org/dc/terms/description": [
            {
                "@value": "<p>This metric evaluates whether there is a resolved metadata representation that conforms to a recognised semantic knowledge representation language.</p>\n\n<p>I1 requires that metadata use a formal, accessible, shared and broadly applicable language for knowledge representation. The purpose of this principle is to ensure that metadata, when retrieved, is expressed in a formally defined knowledge representation language. In this metric, the definition of syntactic and semantic formats follows the [FAIRsharing guidance](<a href=\"https://fairsharing.gitbook.io/fairsharing/about-our-records/fair-assistance/syntactic-vs-semantic-knowledge-representation-languages).\">https://fairsharing.gitbook.io/fairsharing/about-our-records/fair-assistance/syntactic-vs-semantic-knowledge-representation-languages).</a> Under this semantic interpretation, a resource satisfies this metric if the resolved metadata meets these defined semantic criteria for structured representation.</p>\n\n"
            }
        ],
        "http://purl.org/dc/terms/issued": [
            {
                "@type": "http://www.w3.org/2001/XMLSchema#date",
                "@value": "2026-03-01"
