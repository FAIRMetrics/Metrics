        "@value": "https://w3id.org/fair-metrics/general/FM_R1-1_M_StdLic"
      },
      "dc:title": "FAIR Metric - R1.1 - Metadata - discoverable data license in metadata",
      "http://vivoweb.org/ontology/core#abbreviation": "FM_R1-1_M_StdLic",
      "dcat:landingPage": {
        "@id": "https://w3id.org/fair-metrics/general/FM_R1-1_M_StdLic"
      },
      "dc:description": "<p>This metric evaluates whether there is an explicit licence declaration present in the metadata retrieved upon resolution of the provided identifier.</p>\n\n    <p>R1.1 requires that metadata be released with a clear and accessible data usage licence. \nThe purpose of this principle is to ensure that reuse conditions are explicitly stated at the \nlevel of the individual digital object. This metric evaluates whether there is an explicit \nlicence declaration present in the metadata retrieved upon resolution of the provided \nidentifier. Under this interpretation, the evaluation checks whether the resolved \nmetadata contains a licence statement or reference that clearly specifies usage\n conditions for the record or its associated research object. A resource satisfies \n this metric if the resolved metadata includes at least one explicit licence declaration.</p>\n    ",
      "dcat:keyword": [
        "FAIR",
        "R1.1",
        "identifier",
        "metadata"
      ],
