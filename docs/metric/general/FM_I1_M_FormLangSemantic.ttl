<https://w3id.org/fair-metrics/general/FM_I1_M_FormLangSemantic>
    a                          ftr:Metric, dcat:Dataset ;
    rdfs:definedBy            <https://fairmetrics.github.io/Metrics/metric/general/FM_I1_M_FormLangSemantic.ttl> ;

    ftr:identifier            "https://w3id.org/fair-metrics/general/FM_I1_M_FormLangSemantic"^^xsd:anyURI ;
    dcterms:title             "FAIR Metric - I1 - Metadata - Uses Knowledge representation language (semantic)" ;
    vivo:abbreviation         "FM_I1_M_FormLangSemantic" ;
    dcat:landingPage          <https://w3id.org/fair-metrics/general/FM_I1_M_FormLangSemantic> ;

    dcterms:description       """<p>This metric evaluates whether there is a resolved metadata representation that conforms to a recognised semantic knowledge representation language.</p>

<p>I1 requires that metadata use a formal, accessible, shared and broadly applicable language for knowledge representation. The purpose of this principle is to ensure that metadata, when retrieved, is expressed in a formally defined knowledge representation language. In this metric, the definition of syntactic and semantic formats follows the [FAIRsharing guidance](<a href="https://fairsharing.gitbook.io/fairsharing/about-our-records/fair-assistance/syntactic-vs-semantic-knowledge-representation-languages).">https://fairsharing.gitbook.io/fairsharing/about-our-records/fair-assistance/syntactic-vs-semantic-knowledge-representation-languages).</a> Under this semantic interpretation, a resource satisfies this metric if the resolved metadata meets these defined semantic criteria for structured representation.</p>

""" ;
    dcat:keyword              "FAIR", "I1", "identifier", "metadata" ;
dqv:inDimension <https://doi.org/10.25504/FAIRsharing.ec5648> ;
    dcat:landingPage          <https://w3id.org/fair-metrics/general/FM_I1_M_FormLangSemantic> ;

