<https://w3id.org/fair-metrics/general/FM_R1-1_M_StdLic>
    a                          ftr:Metric, dcat:Dataset ;
    rdfs:definedBy            <https://fairmetrics.github.io/Metrics/metric/general/FM_R1-1_M_StdLic.ttl> ;

    ftr:identifier            "https://w3id.org/fair-metrics/general/FM_R1-1_M_StdLic"^^xsd:anyURI ;
    dcterms:title             "FAIR Metric - R1.1 - Metadata - discoverable data license in metadata" ;
    vivo:abbreviation         "FM_R1-1_M_StdLic" ;
    dcat:landingPage          <https://w3id.org/fair-metrics/general/FM_R1-1_M_StdLic> ;

    dcterms:description       """<p>This metric evaluates whether there is an explicit licence declaration present in the metadata retrieved upon resolution of the provided identifier.</p>

    <p>R1.1 requires that metadata be released with a clear and accessible data usage licence. 
The purpose of this principle is to ensure that reuse conditions are explicitly stated at the 
level of the individual digital object. This metric evaluates whether there is an explicit 
licence declaration present in the metadata retrieved upon resolution of the provided 
identifier. Under this interpretation, the evaluation checks whether the resolved 
metadata contains a licence statement or reference that clearly specifies usage
 conditions for the record or its associated research object. A resource satisfies 
 this metric if the resolved metadata includes at least one explicit licence declaration.</p>
    """;
    dcat:keyword              "FAIR", "R1.1", "identifier", "metadata" ;

    dcat:landingPage          <https://w3id.org/fair-metrics/general/FM_R1-1_M_StdLic> ;

    dcterms:creator           [
        a                     vcard:Individual ;
        vcard:fn              "Mark D. Wilkinson" ;
