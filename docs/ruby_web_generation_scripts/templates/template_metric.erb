<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= metric_name || metric_title %></title>
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.5/css/bootstrap.min.css">
</head>
<body>
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.5/js/bootstrap.min.js"></script>
  <style>
    .row { margin-bottom: 10px; }
    .well { margin: 0; padding: 10px; min-height: 40px; }
    .tag_div { margin-right: 10px; }
    .row-equal { display: flex; align-items: stretch; }
    .align-items-center { display: flex; align-items: center; }
    .flex-space-between { display: flex; justify-content: space-between; }
    .text-separation { margin-right: 10px; }
    .status-indicator {
      display: inline-block; width: 12px; height: 12px; border-radius: 50%;
      margin-right: 8px; vertical-align: middle;
    }
    .status-indicator.Active { background-color: #28a745; }
    .status-indicator.Proposed { background-color: #ffc107; }
    .status-indicator.Inactive { background-color: #6c757d; }
    .status-indicator.Deprecated { background-color: #dc3545; }
  </style>

  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <h1 class="text-center"><%= metric_name || metric_title %></h1>
      </div>
    </div>

    <div class="row">
      <div class="col-md-12 well" style="font-size: 16px;">
        <%= metric_description %>
      </div>
    </div>

    <div class="row flex-space-between">
      <div class="col-md-12 align-items-center">
        <h4 class="text-left text-separation">Metric information</h4>
        <a href="<%= metric_turtle %>" title="RDF Turtle">
          <img border="0" src="http://www.w3.org/RDF/icons/rdf_flyer.24" alt="RDF Icon"/>
        </a>
      </div>
    </div>

    <div class="row row-equal">
      <div class="col-md-3 well tag_div"><strong>Title</strong></div>
      <div class="col-md-9 well"><%= metric_title %></div>
    </div>

    <div class="row row-equal">
      <div class="col-md-3 well tag_div"><strong>Identifier</strong></div>
      <div class="col-md-9 well"><a href="<%= metric_identifier %>" target="_blank"><%= metric_identifier %></a></div>
    </div>

    <div class="row row-equal">
      <div class="col-md-3 well tag_div"><strong>Keywords</strong></div>
      <div class="col-md-9 well"><%= metric_keywords %></div>
    </div>

    <div class="row row-equal">
      <div class="col-md-3 well tag_div"><strong>Contact Point</strong></div>
      <div class="col-md-9 well"><%= metric_contactPoint %></div>
    </div>

    <div class="row row-equal">
      <div class="col-md-3 well tag_div"><strong>Version</strong></div>
      <div class="col-md-9 well"><%= metric_version %></div>
    </div>

    <div class="row row-equal">
      <div class="col-md-3 well tag_div"><strong>License</strong></div>
      <div class="col-md-9 well"><a href="<%= metric_license %>" target="_blank"><%= metric_license %></a></div>
    </div>

    <div class="row row-equal">
      <div class="col-md-3 well tag_div"><strong>Principle</strong></div>
      <div class="col-md-9 well"><a href="<%= metric_dimension %>" target="_blank"><%= metric_dimension %></a></div> 
    </div>

    <div class="row row-equal">
      <div class="col-md-3 well tag_div"><strong>Applicable for</strong></div>
      <div class="col-md-9 well">
        <a href="<%= metric_applicable_for %>" target="_blank"><%= metric_applicable_for %></a>
      </div>
    </div>

    <div class="row row-equal">
      <div class="col-md-3 well tag_div"><strong>Supported by</strong></div>
      <div class="col-md-9 well">
        <a href="<%= metric_supported_by %>" target="_blank"><%= metric_supported_by %></a>
      </div>
    </div>

    <div class="row row-equal">
      <div class="col-md-3 well tag_div"><strong>Metric Status</strong></div>
      <div class="col-md-2 well">
        <span class="status-indicator <%= metric_status %>"></span>
        <span><%= metric_status || 'Active' %></span>
      </div>
      <div class="col-md-7">
        <span class="status-indicator Active"></span><strong>Active</strong>
        <span class="status-indicator Proposed"></span><strong>Proposed</strong>
        <span class="status-indicator Inactive"></span><strong>Inactive</strong>
        <span class="status-indicator Deprecated"></span><strong>Deprecated</strong>
      </div>
    </div>

    <div class="row row-equal">
      <div class="col-md-3 well tag_div"><strong>Used in Test</strong></div>
      <div class="col-md-9 well">
        <a href="<%= metric_test || '#' %>" target="_blank"><%= metric_test || '—' %></a>
      </div>
    </div>
  </div>

  <div class="row" style="margin-top: 30px;">
    <div class="col-md-12 text-center">
      FAIR Metrics Catalogue
    </div>
  </div>
</body>
</html>